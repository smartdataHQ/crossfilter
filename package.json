{
  "name": "@smartdatahq/crossfilter",
  "version": "2.0.1",
  "description": "Fast multidimensional filtering with Arrow streaming, WASM filters, and worker-backed dashboard runtimes.",
  "license": "Apache-2.0",
  "keywords": [
    "analytics",
    "arrow",
    "crossfilter",
    "dashboard",
    "visualization",
    "wasm"
  ],
  "author": {
    "name": "SmartData HQ",
    "url": "https://github.com/smartdataHQ"
  },
  "contributors": [
    {
      "name": "Mike Bostock",
      "url": "http://bost.ocks.org/mike"
    },
    {
      "name": "Jason Davies",
      "url": "http://www.jasondavies.com/"
    }
  ],
  "homepage": "https://github.com/smartdataHQ/crossfilter",
  "main": "./crossfilter.js",
  "module": "main.js",
  "types": "./index.d.ts",
  "unpkg": "./crossfilter.min.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartdataHQ/crossfilter.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ranfdev/deepobj": "1.0.2"
  },
  "devDependencies": {
    "apache-arrow": "^21.1.0",
    "d3": "^3.5.17",
    "echarts": "^6.0.0",
    "eslint": "^8.12.0",
    "package-json-versionify": "1.0.2",
    "rollup": "^2.78.1",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-json": "4",
    "rollup-plugin-node-resolve": "5",
    "rollup-plugin-terser": "^7.0.2",
    "semver": "^5.7.0",
    "sinon": "^7.5.0",
    "vitest": "^0.22.1"
  },
  "scripts": {
    "benchmark": "node test/benchmark.js",
    "benchmark:arrow": "node test/benchmark-arrow.mjs",
    "build": "rollup -c rollup.config.js",
    "clean": "rm -f crossfilter.js crossfilter.min.js",
    "test": "vitest && eslint src/"
  },
  "files": [
    "index.js",
    "main.js",
    "src/**",
    "index.d.ts",
    "crossfilter.js",
    "crossfilter.min.js"
  ],
  "eslintConfig": {
    "env": {
      "browser": true,
      "node": true
    },
    "globals": {
      "Uint8Array": true,
      "Uint16Array": true,
      "Uint32Array": true
    },
    "extends": "eslint:recommended"
  }
